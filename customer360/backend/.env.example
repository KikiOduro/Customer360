# Customer360 Backend Environment Variables
# Copy this file to .env and update with your values

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=customer360

# Or use a full DATABASE_URL (overrides individual settings above)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/customer360

# JWT Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production-2026

# Supabase Storage for uploaded source files
SUPABASE_URL=https://bsacwgdxmnuifvhfasof.supabase.co
SUPABASE_STORAGE_BUCKET=user_uploads
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional override if you want to pin the exact public bucket base
# SUPABASE_STORAGE_PUBLIC_BASE=https://bsacwgdxmnuifvhfasof.supabase.co/storage/v1/object/public/user_uploads

# Application Settings
DEBUG=false
